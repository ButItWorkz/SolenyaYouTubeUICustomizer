{
  "manifest_version": 3,
  "name": "Solenya YT Override",
  "version": "1.1",
  "description": "Fixing the garbage YouTube UI.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}